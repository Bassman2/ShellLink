<?xml version="1.0" encoding="utf-8"?>
<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <MSBuildAllProjects Condition="'$(MSBuildVersion)' == '' Or '$(MSBuildVersion)' &lt; '16.0'">$(MSBuildAllProjects);$(MSBuildThisFileFullPath)</MSBuildAllProjects>
    <HasSharedItems>true</HasSharedItems>
    <SharedGUID>cb09c5a6-b436-4a62-beb7-dd8cf891886a</SharedGUID>
  </PropertyGroup>
  <PropertyGroup Label="Configuration">
    <Import_RootNamespace>ShortcutShare</Import_RootNamespace>
  </PropertyGroup>
  <ItemGroup>
    <Compile Include="$(MSBuildThisFileDirectory)BinaryExtentions.cs" />
    <Compile Include="$(MSBuildThisFileDirectory)FileAttributes.cs" />
    <Compile Include="$(MSBuildThisFileDirectory)LinkFlags.cs" />
    <Compile Include="$(MSBuildThisFileDirectory)Shortcut.cs" />
  </ItemGroup>
</Project>